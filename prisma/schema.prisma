generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RagSourceType {
  MARKDOWN
  PDF
  DOCX
  TXT
  URL
  API
  NOTE
  USER_UPLOAD
  OTHER
}

enum RagStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum RagAudience {
  EXTERNAL
  INTERNAL
  RESTRICTED
}

enum RagVisibility {
  CHAT
  OPERATOR
  REVIEW
  EVAL
}

enum RagFeedbackRating {
  GOOD
  BAD
  INCOMPLETE
  UNSAFE
  OUTDATED
}

enum RagReviewStatus {
  PENDING
  APPROVED
  REJECTED
}


// -----------------------------------------------------------------------------
// CUSTOM APP USER / TENANT TABLES: DO NOT RELATE THEM DIRECTLY TO RAG TABLES
// -----------------------------------------------------------------------------
// This schema is the contract used by the MCP server. The MCP tools currently
// create and manage RagCollection -> RagDocument -> RagChunk rows with the
// relationships below. If you add your own app tables such as AppUser, Tenant,
// Workspace, Customer, Organization, Account, etc., keep them decoupled from the
// RAG tables unless you also update and test every MCP read/write path.
//
// SAFE CUSTOMIZATION PATTERN:
//   - Add your custom table if your host app needs it.
//   - Store access/ownership as plain nullable references on a generic scope
//     layer or metadata, for example `scopeExternalRef = "user_123"`.
//   - Let your app authenticate users and decide which external refs are allowed.
//   - Let the RAG/MCP layer resolve those refs as data, not as Prisma relations.
//
// DANGEROUS / LIKELY BREAKING PATTERN:
//   - Do NOT add required fields like `userId String` to RagCollection,
//     RagDocument, or RagChunk unless every MCP create/update path supplies it.
//   - Do NOT add `user AppUser @relation(...)` or similar relations from RAG
//     tables to custom app tables unless you are intentionally forking the MCP
//     contract and updating the tools accordingly.
//   - Do NOT rename existing relation fields, change required/nullability rules,
//     or reinterpret status/audience/visibility enums without MCP changes.
//
// Mental model: external app tables may exist beside the RAG schema, but the RAG
// schema should only receive stable external references. Custom app identity is
// owned by the host app; knowledge organization is owned by Awesome RAG Forge.
// See docs/scoped-knowledge.md before changing schema relationships.
// -----------------------------------------------------------------------------

model RagCollection {
  id          String        @id @default(cuid())
  name        String
  description String?
  category    String?
  domain      String?
  tags        String[]      @default([])
  audience    RagAudience   @default(EXTERNAL)
  visibility  RagVisibility[] @default([CHAT, OPERATOR, REVIEW])
  metadata    Json?
  documents   RagDocument[]
  evalCases   RagEvalCase[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([category])
  @@index([domain])
  @@index([audience])
}

model RagDocument {
  id           String        @id @default(cuid())
  collectionId String
  collection   RagCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  title        String
  sourceType   RagSourceType
  sourceUrl    String?
  storageKey   String?
  category     String?
  domain       String?
  tags         String[]      @default([])
  audience     RagAudience   @default(EXTERNAL)
  visibility   RagVisibility[] @default([CHAT, OPERATOR, REVIEW])
  status       RagStatus     @default(DRAFT)
  metadata     Json?
  chunks       RagChunk[]
  sources      RagSource[]
  reviews      RagReview[]
  feedback     RagFeedback[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([collectionId])
  @@index([status])
  @@index([sourceType])
  @@index([category])
  @@index([domain])
  @@index([audience])
}

model RagChunk {
  id           String        @id @default(cuid())
  documentId   String
  document     RagDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkText    String
  chunkIndex   Int
  pageNumber   Int?
  sectionTitle String?
  tokenCount   Int?
  embedding    Unsupported("vector(768)")?
  status       RagStatus     @default(DRAFT)
  metadata     Json?
  sources      RagSource[]
  reviews      RagReview[]
  feedback     RagFeedback[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([status])
  @@index([sectionTitle])
}

model RagSource {
  id           String      @id @default(cuid())
  documentId   String
  document     RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkId      String?
  chunk        RagChunk?   @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  label        String
  citationText String?
  pageNumber   Int?
  sectionTitle String?
  sourceUrl    String?
  createdAt    DateTime    @default(now())

  @@index([documentId])
  @@index([chunkId])
}

model RagFeedback {
  id               String            @id @default(cuid())
  documentId       String?
  document         RagDocument?      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  chunkId          String?
  chunk            RagChunk?         @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  question         String?
  answer           String?
  rating           RagFeedbackRating
  comment          String?
  failureCategory  String?
  reviewStatus     RagReviewStatus   @default(PENDING)
  resolutionStatus String?
  resolutionNotes  String?
  reviewer         String?
  reviewedAt       DateTime?
  resolvedAt       DateTime?
  metadata         Json?
  createdAt        DateTime          @default(now())

  @@index([documentId])
  @@index([chunkId])
  @@index([rating])
  @@index([reviewStatus])
  @@index([failureCategory])
  @@index([resolvedAt])
}

model RagReview {
  id         String          @id @default(cuid())
  documentId String?
  document   RagDocument?    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkId    String?
  chunk      RagChunk?       @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  status     RagReviewStatus @default(PENDING)
  reviewer   String?
  notes      String?
  createdAt  DateTime        @default(now())
  reviewedAt DateTime?

  @@index([documentId])
  @@index([chunkId])
  @@index([status])
}

/// Assistant identity/config, kept as a singleton row. This is NOT knowledge
/// content — it must never be modeled as a RagDocument/RagChunk, or it would
/// become retrievable and get recited back by the chat model. Writable only
/// through the MCP server (see mcp/rag-manager), read-only from the chat app.
model AssistantConfig {
  id           String   @id @default(cuid())
  name         String
  instructions String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum HarnessRuleKind {
  CAPABILITY
  RESTRICTION
}

enum HarnessRuleScope {
  USER_CHAT
  OPERATOR_AGENT
  MCP_AGENT
  ALL
}

/// Harness rules describe what the read-only chat can and cannot do, in
/// addition to the hardcoded identity/read-only rules in lib/rag/chat-context.ts
/// (which these can never loosen — see lib/rag/harness.ts). Configured only
/// through the MCP server's propose -> approve -> review workflow, the same
/// as knowledge writes. Only status: APPROVED rules are ever surfaced to a
/// connected chat/agent.
model HarnessRule {
  id          String          @id @default(cuid())
  kind        HarnessRuleKind
  statement   String
  scope       HarnessRuleScope @default(USER_CHAT)
  status      RagStatus       @default(DRAFT)
  reason      String?
  warnings    Json?
  reviewer    String?
  reviewNotes String?
  reviewedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([kind])
  @@index([scope])
  @@index([status])
}

model RagEvalCase {
  id              String         @id @default(cuid())
  collectionId    String?
  collection      RagCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  question        String
  expectedAnswer  String?
  expectedSources Json?
  category        String?
  domain          String?
  tags            String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([collectionId])
  @@index([category])
  @@index([domain])
}
