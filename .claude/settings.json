{
  "statusLine": {
    "type": "command",
    "command": "node \"${CLAUDE_PROJECT_DIR:-.}/scripts/dev-mode-statusline.mjs\""
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(.env)",
      "Bash(cat .env)",
      "Bash(cat ./.env)",
      "Bash(less .env)",
      "Bash(more .env)",
      "Bash(head .env)",
      "Bash(tail .env)",
      "Bash(grep * .env)"
    ]
  }
}
