# Required. Must be Postgres with the pgvector extension available (most
# managed providers, including Prisma Postgres, support this) — the schema's
# RagChunk.embedding column is vector(768). `npx prisma db push` will fail
# without it. Ask the user for their real connection string; do not invent one.
DATABASE_URL=""
# Local Docker option after `npm run db:local:up`:
# DATABASE_URL="postgresql://awesome_rag_forge:awesome_rag_forge@127.0.0.1:54329/awesome_rag_forge?schema=public"

# Optional — defaults to "ollama", the only provider implemented today.
# See lib/chat-providers/.
# CHAT_PROVIDER="ollama"

# Optional — defaults shown. Only needed if Ollama runs somewhere other than
# the default local address, or you want a different default chat model.
# Only read when CHAT_PROVIDER is "ollama".
OLLAMA_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5:7b-instruct"

# Optional — defaults to true in this template because this checkout is also
# useful for developers. This flag is only about repository/source-code/schema/
# dependency changes. Normal MCP knowledge-base operations remain available
# either way. Set false for non-technical Operator Mode-only installs.
DEVELOPER_MODE=true

# Optional — template defaults to true for local project use. Missing/unset is
# treated as false, so deployments like Vercel stay closed until you explicitly
# add this env var. Exposes the chat, collections, harness, feedback capture,
# RAG context/debug APIs, document download route, and Ollama helper routes.
ENABLE_TESTING_SURFACE=true

# Optional locally; required before intentionally exposing ENABLE_TESTING_SURFACE=true
# on Vercel or another deployed environment. This protects only the Next.js
# testing UI/API routes. The default stdio MCP server remains local/offline and
# does not use an API key.
APP_API_KEY=""

# Optional: only needed if you run the MCP server's HTTP transport
# (npm run mcp:rag-manager:http) instead of the default stdio transport.
# Defaults are localhost-only on purpose — see docs/security.md before
# changing MCP_HTTP_HOST to anything else.
# MCP_HTTP_HOST="127.0.0.1"
# MCP_HTTP_PORT="3200"

# Optional: only needed if you want to store original uploaded document files.
# Without these, attach_document_file/approve_file_upload return a clear
# configuration error instead of silently storing anything.
# STORAGE_BUCKET=""
# STORAGE_ACCESS_KEY_ID=""
# STORAGE_SECRET_ACCESS_KEY=""
# Optional refinements on top of the three required vars above:
# STORAGE_REGION=""    # defaults to "auto"; set for real AWS S3 (e.g. "us-east-1")
# STORAGE_ENDPOINT=""  # leave unset for AWS S3; set for R2/MinIO/other S3-compatible providers
